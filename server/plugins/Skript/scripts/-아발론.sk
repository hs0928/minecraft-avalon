                {관리자1} command "effect give @e[name=b2] minecraft:speed infinite 10 true"
                {관리자1} command "effect give @e[name=b3] minecraft:speed infinite 10 true"
                {관리자1} command "effect give @e[name=b4] minecraft:speed infinite 10 true"
                {관리자1} command "effect give @e[name=b5] minecraft:speed infinite 10 true"
                
