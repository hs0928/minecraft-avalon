                #원정찬성됨
                set {원정연속반대} to 0
                delete {투표수3}
                add 1 to {원정횟수}
                add 1 to {라운드1}
                play sound "minecraft:2" with volume 0.4 to all players
                wait 2 second
                loop all players:
                    wipe loop-player's sidebar
                console command "item replace entity @a armor.chest with minecraft:light_gray_stained_glass_pane[minecraft:equippable={slot:'chest',camera_overlay:'misc/addil6'}]"
                console command "stopsound @a * minecraft:item.armor.equip_generic"
                play sound "minecraft:entity.experience_orb.pickup" to all players
                wait 60 tick
                console command "item replace entity @a armor.chest with air"
                set {_원정대투표종이주기1} to {원정대구성원::1}
                set {_원정대투표종이주기2} to {원정대구성원::2}
                set {_원정대투표종이주기3} to {원정대구성원::3}
                set {_원정대투표종이주기4} to {원정대구성원::4}
                set {_원정대투표종이주기5} to {원정대구성원::5}
                give 1 paper named "&f원정대 투표" to {_원정대투표종이주기1} parsed as player
                give 1 paper named "&f원정대 투표" to {_원정대투표종이주기2} parsed as player
                give 1 paper named "&f원정대 투표" to {_원정대투표종이주기3} parsed as player
                give 1 paper named "&f원정대 투표" to {_원정대투표종이주기4} parsed as player
                give 1 paper named "&f원정대 투표" to {_원정대투표종이주기5} parsed as player
                delete {원정대성공투표}
                delete {원정대실패투표}
                set {성실Timer::%uuid of player%} to 100
                set {성실MaxTimer::%uuid of player%} to 100
                create bossbar titled "&f[&9투표까지 남은 시간: &b%{성실Timer::%uuid of player%}%&9초&f]" and id "성실타이머" for all players with progress 100 with colors blue with style segmented 10

            if {원정대반대투표} >= {원정대찬성투표}:
                #원정반대됨
                add 1 to {원정연속반대}
                loop all players:
                    wipe loop-player's sidebar
                if {원정연속반대} < 5:
                    delete {투표수1}
                    console command "item replace entity @a armor.chest with minecraft:light_gray_stained_glass_pane[minecraft:equippable={slot:'chest',camera_overlay:'misc/addil8'}]"
                    console command "stopsound @a * minecraft:item.armor.equip_generic"
                    play sound "minecraft:15" with volume 0.2 to all players
                    wait 60 tick
                    console command "item replace entity @a armor.chest with minecraft:light_gray_stained_glass_pane[minecraft:equippable={slot:'chest',camera_overlay:'misc/addil2'}]"
                    console command "stopsound @a * minecraft:item.armor.equip_generic"
                    play sound "minecraft:13" with volume 0.2 to all players
                    wait 3 seconds
                    console command "item replace entity @a armor.chest with minecraft:air"
                    give 1 paper named "&f대표 선정" to all players
                    set {대표Timer::%uuid of player%} to 100
                    set {대표MaxTimer::%uuid of player%} to 100
                    create bossbar titled "&f[&9투표까지 남은 시간: &b%{대표Timer::%uuid of player%}%&9초&f]" and id "대표타이머" for all players with progress 100 with colors blue with style segmented 10

                else if {원정연속반대} >= 5:
                     
                    #delete {기본bgm재생}
                    console command "stopsound @a"
                    delete {역할타이틀로확인}
                    delete {역할확인종이}
                    console command "item replace entity @a armor.head with minecraft:light_gray_stained_glass_pane[minecraft:equippable={slot:'head',camera_overlay:'misc/fullil3'}]"
                    console command "stopsound @a * minecraft:item.armor.equip_generic"
                    loop {악::*}:
                        add 1 to {게임승리횟수::%loop-value%}
                    console command "gamemode spectator @a"
                    play sound "minecraft:4" with volume 0.4 to all players
                    console command "tp @a 360 20 583"
                    console command "tp %{관리자1}% 360 18 571 0 0"
                    wait 1 tick
                    make {관리자1} run command "npc create 설정" as op
                    make {관리자1} run command "npc skin notch" as op
                    console command "effect clear @a"
                    
                    console command "clear @a paper"
                    wait 160 tick
                    console command "item replace entity @a armor.head with air"
                    console command "gamemode survival @a"

command z대표투표다음:
    trigger:
        if player is op:
            console command "clear @a paper"
            delete {투표수1}
            loop all players:
                delete {대표Timer::%uuid of loop-player%}
                delete {대표MaxTimer::%uuid of loop-player%}
            remove bossbar "대표타이머"
            delete {대표}
            set {_topValue} to -1
            loop all players:
                set {_uuid} to uuid of loop-player
                set {_value} to {득표수::%{_uuid}%}
                if {_value} is set:
                    if {_value} > {_topValue}: 
                        set {_topValue} to {_value}
                        set {_topPlayers::*} to loop-player
                    else if {_value} = {_topValue}:
                        add loop-player to {_topPlayers::*}
            if {_topPlayers::*} is set:

                if size of {_topPlayers::*} = 1:
                    set {대표} to {_topPlayers::1}
                    console command "item replace entity @a armor.chest with minecraft:light_gray_stained_glass_pane[minecraft:equippable={slot:'chest',camera_overlay:'misc/addil4'}]"
                    console command "stopsound @a * minecraft:item.armor.equip_generic"
                    play sound "minecraft:11" with volume 0.1 to all players

                else if size of {_topPlayers::*} is bigger than 1:
                    send "{@시스템}&e최다 득표를 받은 플레이어가 2명 이상입니다%nl%{@시스템}&b3초후 최다 득표자중 랜덤으로 대표를 선정합니다" to all players
                    play sound "minecraft:entity.experience_orb.pickup" to all players
                    wait 1 second
                    send "{@시스템}&b2초후 최다 득표자중 랜덤으로 대표를 선정합니다" to all players
                    play sound "minecraft:entity.experience_orb.pickup" to all players
                    wait 1 second
                    send "{@시스템}&b1초후 최다 득표자중 랜덤으로 대표를 선정합니다" to all players
                    play sound "minecraft:entity.experience_orb.pickup" to all players
                    wait 1 second
                    send subtitle "" to all players
                    loop 24 times:
                        set {_랜덤임시} to random element out of {_topPlayers::*}
                        send title "&e%{_랜덤임시}%" to all players with fade in 0 ticks
                        play sound "minecraft:entity.experience_orb.pickup" to all players
                        wait 2 tick
                    set {대표} to random element out of {_topPlayers::*}
                    send title " " to all players with fade in 0 ticks
                    console command "item replace entity @a armor.chest with minecraft:light_gray_stained_glass_pane[minecraft:equippable={slot:'chest',camera_overlay:'misc/addil4'}]"
                    console command "stopsound @a * minecraft:item.armor.equip_generic"
                    play sound "minecraft:11" with volume 0.1 to all players
                send "{@시스템}대표 : %{대표}%" to all players
                delete {_topPlayers::*}
                delete {득표수::*}
                wait 60 tick
                console command "item replace entity @a armor.chest with minecraft:air"
                #원정대구성 GUI 열기
                delete {원정대구성원::*}
                console command "item replace entity @a armor.chest with minecraft:light_gray_stained_glass_pane[minecraft:equippable={slot:'chest',camera_overlay:'misc/addil7'}]"
                console command "stopsound @a * minecraft:item.armor.equip_generic"
                play sound "minecraft:10" with volume 0.1 to all players
                send "{@시스템}&b대표가 원정대를 구성할때까지 기다려주세요" to all players
                if {요정여부} is true:
                    delete {요정사람}
                    if {대표} is {접속카운트1}:
                        set {요정사람} to {접속카운트2}
                    if {대표} is {접속카운트2}:
                        set {요정사람} to {접속카운트3}
                    if {대표} is {접속카운트3}:
                        set {요정사람} to {접속카운트4}
                    if {대표} is {접속카운트4}:
                        set {요정사람} to {접속카운트5}
                    if {대표} is {접속카운트5}:
                        set {요정사람} to {접속카운트6}
                    if {대표} is {접속카운트6}:
                        set {요정사람} to {접속카운트7}
                    if {대표} is {접속카운트7}:
                        set {요정사람} to {접속카운트8}
                    if {대표} is {접속카운트8}:
                        set {요정사람} to {접속카운트9}
                    if {대표} is {접속카운트9}:
                        set {요정사람} to {접속카운트10}
                    if {대표} is {접속카운트10}:
                        set {요정사람} to {접속카운트1}
                loop all players:
                    wipe loop-player's sidebar
                give 1 paper named "&f원정대 구성" to {대표}
                if {접속인원수카운트} is 5:
                    if {원정횟수} is 0:
                        set {원정대최대인원} to 2
                    if {원정횟수} is 1:
                        set {원정대최대인원} to 3
                    if {원정횟수} is 2:
                        set {원정대최대인원} to 2
                    if {원정횟수} is 3:
                        set {원정대최대인원} to 3
                    if {원정횟수} is 4:
                        set {원정대최대인원} to 3
                if {접속인원수카운트} is 6:
                    if {원정횟수} is 0:
                        set {원정대최대인원} to 2
                    if {원정횟수} is 1:
                        set {원정대최대인원} to 3
                    if {원정횟수} is 2:
                        set {원정대최대인원} to 4
                    if {원정횟수} is 3:
                        set {원정대최대인원} to 3
                    if {원정횟수} is 4:
                        set {원정대최대인원} to 4
                if {접속인원수카운트} is 7:
                    if {원정횟수} is 0:
                        set {원정대최대인원} to 2
                    if {원정횟수} is 1:
                        set {원정대최대인원} to 3
                    if {원정횟수} is 2:
                        set {원정대최대인원} to 3
                    if {원정횟수} is 3:
                        set {원정대최대인원} to 4
                    if {원정횟수} is 4:
                        set {원정대최대인원} to 4
                if {접속인원수카운트} is 8 or 9 or 10:
                    if {원정횟수} is 0:
                        set {원정대최대인원} to 3
                    if {원정횟수} is 1:
                        set {원정대최대인원} to 4
                    if {원정횟수} is 2:
                        set {원정대최대인원} to 4
                    if {원정횟수} is 3:
                        set {원정대최대인원} to 5
                    if {원정횟수} is 4:
                        set {원정대최대인원} to 5
                wait 60 tick
                console command "item replace entity @a armor.chest with minecraft:air"
