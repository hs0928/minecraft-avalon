options:
    시스템: &7<&e시스템&7> &e
    오류: &7<&e시스템&7> &c

on chat:
    if name of player is "kuiki771":
        set the chat format to "&f< 끠끼 > : [message]"
    if name of player is "_DIE_MF_DIE_":
        set the chat format to "&f< 머독 > : [message]"
    if name of player is "DDARIN":
        set the chat format to "&f< 따린 > : [message]"
    if name of player is "Gyeolhee":
        set the chat format to "&f< 민결희 > : [message]"
    if name of player is "9ambler":
        set the chat format to "&f< 감블러 > : [message]"
    if name of player is "Danz_":
        set the chat format to "&f< 단즈 > : [message]"
    if name of player is "Floweressloe":
        set the chat format to "&f< 로에 > : [message]"
    if name of player is "42dadada_":
        set the chat format to "&f< 사이다 > : [message]"

on join:
    if {선인원} is not set:
        set {선인원} to 2
    if {악인원} is not set:
        set {악인원} to 2
    if {퍼시벌} is not set:
        set {퍼시벌} to true
    if {오베론} is not set:
        set {오베론} to true
    if {모르가나} is not set:
        set {모르가나} to true
    if {모드레드} is not set:
        set {모드레드} to true
    if {요정} is not set:
        set {요정} to 1
    if {요정여부} is not set:
        set {요정여부} to false
    console command "gamerule sendCommandFeedback false"

