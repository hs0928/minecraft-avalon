            remove bossbar "대표타이머"
            remove bossbar "찬반타이머"
            remove bossbar "성실타이머"
            loop all players:
                delete {대표Timer::%uuid of loop-player%}
                delete {대표MaxTimer::%uuid of loop-player%}
            delete {암살자종이}
            console command "tp %{관리자::1}% 405 21 345"
            console command "tp %{관리자::2}% 405 21 346"
            console command "tp %{관리자::3}% 405 21 347"
            console command "tp %{관리자::4}% 405 21 348"
            console command "tp %{접속카운트1}% 376 21 344"
            console command "tp %{접속카운트2}% 376 21 350"
            console command "tp %{접속카운트3}% 381 21 354"
            console command "tp %{접속카운트4}% 386 21 354"
            console command "tp %{접속카운트5}% 391 21 354"
            console command "tp %{접속카운트6}% 396 21 350"
            console command "tp %{접속카운트7}% 396 21 344"
            console command "tp %{접속카운트8}% 391 21 340"
            console command "tp %{접속카운트9}% 386 21 340"
            console command "tp %{접속카운트10}% 381 21 340"
            console command "gamemode survival @a"
            #set {기본bgm재생} to true
            #make player run command "기본bgm" as op
            play sound "minecraft:1" with volume 0.02 to all players
            console command "clear @a"

            wait 20 tick

            send "{@시스템}&b3초후 캐릭터(역할)이 랜덤으로 정해집니다" to all players
            play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            wait 1 second
            send "{@시스템}&b2초후 캐릭터(역할)이 랜덤으로 정해집니다" to all players
            play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            wait 1 second
            send "{@시스템}&b1초후 캐릭터(역할)이 랜덤으로 정해집니다" to all players
            play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            wait 1 second
            console command "effect give @a darkness infinite 1 true"
            wait 3 second
            console command "item replace entity @a armor.chest with minecraft:light_gray_stained_glass_pane[minecraft:equippable={slot:'chest',camera_overlay:'misc/addil1'}]"
            wait 1 tick
            console command "stopsound @a * minecraft:item.armor.equip_generic"
            play sound "minecraft:9" with volume 0.2 to all players
            play sound "minecraft:block.stone_button.click_off" with pitch 2 to all players
            wait 59 tick
            console command "item replace entity @a armor.chest with minecraft:air"
            add {관리자제외전체인원::*} to {선악지정::*}
            loop {선인원} times:
                set {_selected} to random element of {선악지정::*}
                remove {_selected} from {선악지정::*}
                add {_selected} to {선::*}
                add {_selected} to {선랜덤역할지정::*}
                set {역할군이름::%{_selected}%} to "&9선"

            loop {악인원} times:
                set {_selected} to random element of {선악지정::*}
                remove {_selected} from {선악지정::*}
                add {_selected} to {악::*}
                add {_selected} to {악랜덤역할지정::*}
                set {역할군이름::%{_selected}%} to "&c악"
            
            set {_멀린랜덤} to random element of {선랜덤역할지정::*}
            remove {_멀린랜덤} from {선랜덤역할지정::*}
            add {_멀린랜덤} to {멀린캐릭터::*}
            
            if {퍼시벌} is true:
                set {_퍼시벌랜덤} to random element of {선랜덤역할지정::*}
                remove {_퍼시벌랜덤} from {선랜덤역할지정::*}
                add {_퍼시벌랜덤} to {퍼시벌캐릭터::*}
            
            loop 10 times:
                set {_역할없음랜덤} to random element of {선랜덤역할지정::*}
                remove {_역할없음랜덤} from {선랜덤역할지정::*}
                add {_역할없음랜덤} to {역할없음선캐릭터::*}
            

            set {_암살자랜덤} to random element of {악랜덤역할지정::*}
            remove {_암살자랜덤} from {악랜덤역할지정::*}
            add {_암살자랜덤} to {암살자캐릭터::*}
            
            if {오베론} is true:
                set {_오베론랜덤} to random element of {악랜덤역할지정::*}
                remove {_오베론랜덤} from {악랜덤역할지정::*}
                add {_오베론랜덤} to {오베론캐릭터::*}
            
            if {모르가나} is true:
                set {_모르가나랜덤} to random element of {악랜덤역할지정::*}
                remove {_모르가나랜덤} from {악랜덤역할지정::*}
                add {_모르가나랜덤} to {모르가나캐릭터::*}
            
            if {모드레드} is true:
                set {_모드레드랜덤} to random element of {악랜덤역할지정::*}
                remove {_모드레드랜덤} from {악랜덤역할지정::*}
                add {_모드레드랜덤} to {모드레드캐릭터::*}

            loop 10 times:
                set {_역할없음랜덤} to random element of {악랜덤역할지정::*}
                remove {_역할없음랜덤} from {악랜덤역할지정::*}
                add {_역할없음랜덤} to {역할없음악캐릭터::*}
            
            
            set {역할확인종이} to true
            set {역할타이틀로확인} to true

            loop all players:
                set {카드타이틀로확인::%loop-player%} to true

            play sound "minecraft:7" to {선::*}
            play sound "minecraft:8" to {악::*}

            wait 60 tick
            loop all players:
                delete {카드타이틀로확인::%loop-player%}
                console command "item replace entity @a armor.feet with minecraft:air"

            wait 30 tick
            #정체 확인
            send "{@시스템}&c악의 세력 %nl%&e %{암살자캐릭터::*}%" to {암살자캐릭터::*}#%{모드레드캐릭터::*}%, %{역할없음악캐릭터::*}%
            if {모르가나} is true:
