                {관리자1} command "item replace entity @e[name=a4] weapon.mainhand with iron_sword"
                {관리자1} command "item replace entity @e[name=a5] weapon.mainhand with iron_sword"
                
                wait 30 tick

                loop 3 times:
                    #데미지
                    make {관리자1} run command "npc sel a1" as op
                    make {관리자1} run command "npc hurt 8" as op
                    make {관리자1} run command "npc sel a2" as op
                    make {관리자1} run command "npc hurt 8" as op
