                else if {멀린캐릭터::*} does not contain {접속카운트10}:
                    
                    console command "item replace entity @a armor.head with minecraft:light_gray_stained_glass_pane[minecraft:equippable={slot:'head',camera_overlay:'misc/fullil1'}]"
