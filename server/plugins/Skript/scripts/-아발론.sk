                    console command "item replace entity @a armor.head with minecraft:light_gray_stained_glass_pane[minecraft:equippable={slot:'head',camera_overlay:'misc/fullil2'}]"
                    console command "stopsound @a * minecraft:item.armor.equip_generic"
