                console command "tp %{접속카운트4}% 386 21 354"
                console command "tp %{접속카운트5}% 391 21 354"
                console command "tp %{접속카운트6}% 396 21 350"
                console command "tp %{접속카운트7}% 396 21 344"
                console command "tp %{접속카운트8}% 391 21 340"
                console command "tp %{접속카운트9}% 386 21 340"
                console command "tp %{접속카운트10}% 381 21 340"
                send title "∴ " to all players for 5 second
                play sound "minecraft:5" with volume 0.3 to all players
                wait 8 second
                if {원정성공} >= 3:
                    send title "&e당신은 &c암살자&e 입니다. 멀린을 지목하세요." with subtitle "&c멀린은 지목한 즉시 투표됩니다." to {암살자캐릭터::*} for 3 second
                    set {암살자종이} to {암살자캐릭터::1}
                    give 1 paper named "&c멀린을 지목하세요." to {암살자종이}

