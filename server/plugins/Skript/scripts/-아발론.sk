            delete {원정대구성원::*}
            delete {대표}
            delete {득표수::*}
            delete {원정연속반대}
            set {라운드1} to 0
            set {원정횟수} to 0
            delete {원정성공}
            delete {원정실패}
            delete {투표수1}
            delete {투표수2}
