                        make {관리자1} run command "npc hurt 8" as op
                    if size of {원정대구성원::*} >= 5:
                        make {관리자1} run command "npc sel a5" as op
                        make {관리자1} run command "npc hurt 8" as op
                    
                    
                    wait 12 tick

                    make {손흔들기변수::*} swing their main hand
                    
                    wait 3 tick
                    
                    make {관리자1} run command "npc sel b1" as op
                    make {관리자1} run command "npc hurt 8" as op
                    make {관리자1} run command "npc sel b2" as op
