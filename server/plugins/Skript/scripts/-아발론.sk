command 설정:
    trigger:
        if player is op:
            open chest with 3 rows named "&9설정" to player
            play sound "minecraft:entity.experience_orb.pickup" to player
            set slot 10 of current inventory of player to itemsadder item "ab:job" named "&b특수 직업 설정"
            set slot 12 of current inventory of player to itemsadder item "ab:role" named "&e역할 인원 설정"
            set slot 14 of current inventory of player to itemsadder item "ab:fairy" named "&b요정 설정"
            set slot 16 of current inventory of player to itemsadder item "ab:start" named "&a게임 시작"

on inventory close:
    if player's slot 9 is paper:
        set slot 9 of player's inventory to air

on inventory click:
    if inventory name is "&9설정":
        cancel event
        
        if clicked slot is 10:#<-----------------------------------------------------------------------------특수직업설정 GUI
            open chest with 6 rows named "&b특수 직업 설정" to player
            play sound "minecraft:entity.experience_orb.pickup" to player
            set slot 10 of current inventory of player to itemsadder item "ab:card1"
            set slot 13 of current inventory of player to itemsadder item "ab:card2"
            set slot 16 of current inventory of player to itemsadder item "ab:card3"
            set slot 37 of current inventory of player to itemsadder item "ab:card4"
            set slot 40 of current inventory of player to itemsadder item "ab:card5"
            set slot 43 of current inventory of player to itemsadder item "ab:card6"
            set slot 19 of current inventory of player to lime wool named "&a활성화"
            set slot 25 of current inventory of player to lime wool named "&a활성화"
            set slot 9 of player's inventory to itemsadder item "_iainternal:icon_left_blue"
            if {퍼시벌} is true:
                set slot 22 of current inventory of player to lime wool named "&a활성화"
            else:
                set slot 22 of current inventory of player to red wool named "&c비활성화"
            if {오베론} is true:
                set slot 46 of current inventory of player to lime wool named "&a활성화"
            else:
                set slot 46 of current inventory of player to red wool named "&c비활성화"
            if {모르가나} is true:
                set slot 49 of current inventory of player to lime wool named "&a활성화"
            else:
                set slot 49 of current inventory of player to red wool named "&c비활성화"
            if {모드레드} is true:
                set slot 52 of current inventory of player to lime wool named "&a활성화"
            else:
                set slot 52 of current inventory of player to red wool named "&c비활성화"
        
        if clicked slot is 12:#<-----------------------------------------------------------------------------역할인원설정 GUI
            open chest with 5 rows named "&e역할 인원 설정" to player
            play sound "minecraft:entity.experience_orb.pickup" to player
            set slot 29 of current inventory of player to itemsadder item "ab:down" named "&c제거"
            set slot 20 of current inventory of player to {선인원} of itemsadder item "ab:good" named "&a선인원"
            set slot 11 of current inventory of player to itemsadder item "ab:up" named "&a추가"
            set slot 33 of current inventory of player to itemsadder item "ab:down" named "&c제거"
            set slot 24 of current inventory of player to {악인원} of itemsadder item "ab:bad" named "&c악인원"
            set slot 15 of current inventory of player to itemsadder item "ab:up" named "&a추가"
            set slot 36 of player's current inventory to itemsadder item "_iainternal:icon_left_blue"
        
        if clicked slot is 14:#<-----------------------------------------------------------------------------요정설정 GUI
            open chest with 5 rows named "&b요정 설정" to player
            play sound "minecraft:entity.experience_orb.pickup" to player
            set slot 31 of current inventory of player to itemsadder item "ab:down" named "&c제거"
            if {요정여부} is true:
                set slot 22 of current inventory of player to {요정} of itemsadder item "ab:fairy" named "&a요정"
            else:
                set slot 22 of current inventory of player to itemsadder item "ab:fairy" named "&c요정"
            set slot 13 of current inventory of player to itemsadder item "ab:up" named "&a추가"
            set slot 36 of player's current inventory to itemsadder item "_iainternal:icon_left_blue"
        
        if clicked slot is 16:
            close player's inventory
            execute player command "게임시작"

    if inventory name is "&e역할 인원 설정":#<-----------------------------------------------------------------------------역할인원설정 인벤토리 클릭
        cancel event
        if clicked slot is 29:
            if {선인원} is bigger than 2:
                remove 1 from {선인원}
                set slot 20 of current inventory of player to {선인원} of itemsadder item "ab:good" named "&a선인원"
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            else:
                play sound "entity.enderman.teleport" with volume 0.5 to player
        if clicked slot is 11:
            if 6 is bigger than {선인원}:
                add 1 to {선인원}
                set slot 20 of current inventory of player to {선인원} of itemsadder item "ab:good" named "&a선인원"
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            else:
                play sound "entity.enderman.teleport" with volume 0.5 to player
        if clicked slot is 33:
            if {악인원} is bigger than 2:
                remove 1 from {악인원}
                set slot 24 of current inventory of player to {악인원} of itemsadder item "ab:bad" named "&a선인원"
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            else:
                play sound "entity.enderman.teleport" with volume 0.5 to player
        if clicked slot is 15:
            if 6 is bigger than {악인원}:
                add 1 to {악인원}
                set slot 24 of current inventory of player to {악인원} of itemsadder item "ab:bad" named "&c악인원"
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            else:
                play sound "entity.enderman.teleport" with volume 0.5 to player
        if clicked slot is 36:
            open chest with 3 rows named "&9설정" to player
            play sound "minecraft:entity.experience_orb.pickup" to player
            set slot 10 of current inventory of player to itemsadder item "ab:job" named "&b특수 직업 설정"
            set slot 12 of current inventory of player to itemsadder item "ab:role" named "&e역할 인원 설정"
            set slot 14 of current inventory of player to itemsadder item "ab:fairy" named "&b요정 설정"
            set slot 16 of current inventory of player to itemsadder item "ab:start" named "&a게임 시작"
    
    if inventory name is "&b특수 직업 설정":#<-----------------------------------------------------------------------------특수직업설정 인벤토리 클릭
        cancel event
        if clicked slot is 22:
            if {퍼시벌} is true:
                set slot 22 of current inventory of player to red wool named "&c비활성화"
                set {퍼시벌} to false
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            else:
                set slot 22 of current inventory of player to lime wool named "&a활성화"
                set {퍼시벌} to true
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
        if clicked slot is 46:
            if {오베론} is true:
                set slot 46 of current inventory of player to red wool named "&c비활성화"
                set {오베론} to false
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            else:
                set slot 46 of current inventory of player to lime wool named "&a활성화"
                set {오베론} to true
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
        if clicked slot is 49:
            if {모르가나} is true:
                set slot 49 of current inventory of player to red wool named "&c비활성화"
                set {모르가나} to false
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            else:
                set slot 49 of current inventory of player to lime wool named "&a활성화"
                set {모르가나} to true
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
        if clicked slot is 52:
            if {모드레드} is true:
                set slot 52 of current inventory of player to red wool named "&c비활성화"
                set {모드레드} to false
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            else:
                set slot 52 of current inventory of player to lime wool named "&a활성화"
                set {모드레드} to true
                play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
        if clicked slot is 9:
            open chest with 3 rows named "&9설정" to player
            play sound "minecraft:entity.experience_orb.pickup" to player
            set slot 10 of current inventory of player to itemsadder item "ab:job" named "&b특수 직업 설정"
            set slot 12 of current inventory of player to itemsadder item "ab:role" named "&e역할 인원 설정"
            set slot 14 of current inventory of player to itemsadder item "ab:fairy" named "&b요정 설정"
            set slot 16 of current inventory of player to itemsadder item "ab:start" named "&a게임 시작"
    
    if inventory name is "&b요정 설정":#<-----------------------------------------------------------------------------요정설정 인벤토리 클릭
        cancel event
        if clicked slot is 31:
            if {요정여부} is true:
                if {요정} is bigger than 2:
                    remove 1 from {요정}
                    wait 1 tick
                    set slot 22 of current inventory of player to {요정} of itemsadder item "ab:fairy" named "&a요정"
                    play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
                else:
                    play sound "entity.enderman.teleport" with volume 0.5 to player
        if clicked slot is 13:
            if {요정여부} is true:
                if 5 is bigger than {요정}:
                    add 1 to {요정}
                    wait 1 tick
                    set slot 22 of current inventory of player to {요정} of itemsadder item "ab:fairy" named "&a요정"
                    play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
                else:
                    play sound "entity.enderman.teleport" with volume 0.5 to player
        if clicked slot is 22:
            if {요정여부} is false:
                set {요정여부} to true
                set slot 22 of current inventory of player to {요정} of itemsadder item "ab:fairy" named "&a요정"
                play sound "minecraft:entity.experience_orb.pickup" to player
            else:
                set {요정여부} to false
                set slot 22 of current inventory of player to itemsadder item "ab:fairy" named "&c요정"
                play sound "minecraft:entity.experience_orb.pickup" to player
        if clicked slot is 36:
            open chest with 3 rows named "&9설정" to player
            play sound "minecraft:entity.experience_orb.pickup" to player
            set slot 10 of current inventory of player to itemsadder item "ab:job" named "&b특수 직업 설정"
            set slot 12 of current inventory of player to itemsadder item "ab:role" named "&e역할 인원 설정"
            set slot 14 of current inventory of player to itemsadder item "ab:fairy" named "&b요정 설정"
            set slot 16 of current inventory of player to itemsadder item "ab:start" named "&a게임 시작"

on rightclick on entity:
    if event-entity's name is "설정":
        execute player command "설정"

on join:# "#나중에접속관련참고" 보고하기
    console command "clear %player%"
    console command "tp %player% 360 18 575"
    if {접속카운트1} is not set:
        set {접속카운트1} to name of player
        #console command "스킨다운로드 %player% 1.png plugins/ItemsAdder/contents/test/resourcepack/assets/test/textures/skin"
    else if {접속카운트1} is set:
        if {접속카운트2} is not set:
            set {접속카운트2} to name of player
            #console command "스킨다운로드 %player% 2.png plugins/ItemsAdder/contents/test/resourcepack/assets/test/textures/skin"
        else if {접속카운트2} is set:
            if {접속카운트3} is not set:
                set {접속카운트3} to name of player
                #console command "스킨다운로드 %player% 3.png plugins/ItemsAdder/contents/test/resourcepack/assets/test/textures/skin"
            else if {접속카운트3} is set:
                if {접속카운트4} is not set:
                    set {접속카운트4} to name of player
                    #console command "스킨다운로드 %player% 4.png plugins/ItemsAdder/contents/test/resourcepack/assets/test/textures/skin"
                else if {접속카운트4} is set:
                    if {접속카운트5} is not set:
                        set {접속카운트5} to name of player
                        #console command "스킨다운로드 %player% 5.png plugins/ItemsAdder/contents/test/resourcepack/assets/test/textures/skin"
                    else if {접속카운트5} is set:
                        if {접속카운트6} is not set:
                            set {접속카운트6} to name of player
                            #console command "스킨다운로드 %player% 6.png plugins/ItemsAdder/contents/test/resourcepack/assets/test/textures/skin"
                        else if {접속카운트6} is set:
                            if {접속카운트7} is not set:
                                set {접속카운트7} to name of player
                                #console command "스킨다운로드 %player% 7.png plugins/ItemsAdder/contents/test/resourcepack/assets/test/textures/skin"
                            else if {접속카운트7} is set:
                                if {접속카운트8} is not set:
                                    set {접속카운트8} to name of player
                                    #console command "스킨다운로드 %player% 8.png plugins/ItemsAdder/contents/test/resourcepack/assets/test/textures/skin"
                                else if {접속카운트8} is set:
                                    if {접속카운트9} is not set:
                                        set {접속카운트8} to name of player
                                        #console command "스킨다운로드 %player% 9.png plugins/ItemsAdder/contents/test/resourcepack/assets/test/textures/skin"
                                    else if {접속카운트9} is set:
                                        if {접속카운트10} is not set:
                                            set {접속카운트10} to name of player
                                            #console command "스킨다운로드 %player% 10.png plugins/ItemsAdder/contents/test/resourcepack/assets/test/textures/skin"

on server stop:
    #if "%{접속카운트1}%" is "%name of player%":
    delete {접속카운트1}
    #if "%{접속카운트2}%" is "%name of player%":
    delete {접속카운트2}
    #if "%{접속카운트3}%" is "%name of player%":
    delete {접속카운트3}
    #if "%{접속카운트4}%" is "%name of player%":
    delete {접속카운트4}
    #if "%{접속카운트5}%" is "%name of player%":
    delete {접속카운트5}
    #if "%{접속카운트6}%" is "%name of player%":
    delete {접속카운트6}
    #if "%{접속카운트7}%" is "%name of player%":
    delete {접속카운트7}
    #if "%{접속카운트8}%" is "%name of player%":
    delete {접속카운트8}
    #if "%{접속카운트9}%" is "%name of player%":
    delete {접속카운트9}
    #if "%{접속카운트10}%" is "%name of player%":
    delete {접속카운트10}
    delete {관리자::*}
    delete {관리자1}
    delete {관리자2}

on quit:
    if "%{접속카운트1}%" is "%name of player%":
        delete {접속카운트1}
    if "%{접속카운트2}%" is "%name of player%":
        delete {접속카운트2}
    if "%{접속카운트3}%" is "%name of player%":
        delete {접속카운트3}
    if "%{접속카운트4}%" is "%name of player%":
        delete {접속카운트4}
    if "%{접속카운트5}%" is "%name of player%":
        delete {접속카운트5}
    if "%{접속카운트6}%" is "%name of player%":
        delete {접속카운트6}
    if "%{접속카운트7}%" is "%name of player%":
        delete {접속카운트7}
    if "%{접속카운트8}%" is "%name of player%":
        delete {접속카운트8}
    if "%{접속카운트9}%" is "%name of player%":
        delete {접속카운트9}
    if "%{접속카운트10}%" is "%name of player%":
        delete {접속카운트10}

on quit:
    if player is {관리자1}:
        delete {관리자1}
    remove player from {관리자::*}

every 2 tick:
	loop all players:
		if {대표Timer::%uuid of loop-player%} is set:
			if {대표Timer::%uuid of loop-player%} is 0:
				delete {대표Timer::%uuid of loop-player%}
				delete {대표MaxTimer::%uuid of loop-player%}
				remove bossbar "대표타이머"
				set {_임시명령어} to random element of all players
				make {_임시명령어} run command "z대표투표다음" as op
				stop
			subtract 0.1 from {대표Timer::%uuid of loop-player%}
			set {_per} to {대표Timer::%uuid of loop-player%}/{대표MaxTimer::%uuid of loop-player%}*100
			if {_per} is between 80 and 100:
				set bossbar "대표타이머" color to blue
			else if {_per} is between 50 and 79.99:
				set bossbar "대표타이머" color to green
			else if {_per} is between 20 and 49.99:
				set bossbar "대표타이머" color to yellow
			else if {_per} is between 0 and 19.99:
				set bossbar "대표타이머" color to red
			set bossbar "대표타이머" progress to {_per}
			set bossbar "대표타이머" title to "&f[&9투표까지 남은 시간: &f[&b%{대표Timer::%uuid of loop-player%}%&9초&f]"	

every 2 tick:
	loop all players:
		if {찬반Timer::%uuid of loop-player%} is set:
			if {찬반Timer::%uuid of loop-player%} is 0:
				delete {찬반Timer::%uuid of loop-player%}
				delete {찬반MaxTimer::%uuid of loop-player%}
				remove bossbar "찬반타이머"
				set {_임시명령어} to random element of all players
				make {_임시명령어} run command "z찬반투표다음" as op 
				stop
			subtract 0.1 from {찬반Timer::%uuid of loop-player%}
			set {_per} to {찬반Timer::%uuid of loop-player%}/{찬반MaxTimer::%uuid of loop-player%}*100
			if {_per} is between 80 and 100:
				set bossbar "찬반타이머" color to blue
			else if {_per} is between 50 and 79.99:
				set bossbar "찬반타이머" color to green
			else if {_per} is between 20 and 49.99:
				set bossbar "찬반타이머" color to yellow
			else if {_per} is between 0 and 19.99:
				set bossbar "찬반타이머" color to red
			set bossbar "찬반타이머" progress to {_per}
			set bossbar "찬반타이머" title to "&f[&9투표까지 남은 시간: &f[&b%{찬반Timer::%uuid of loop-player%}%&9초&f]"	

every 2 tick:
	loop all players:
		if {성실Timer::%uuid of loop-player%} is set:
			if {성실Timer::%uuid of loop-player%} is 0:
				delete {성실Timer::%uuid of loop-player%}
				delete {성실MaxTimer::%uuid of loop-player%}
				remove bossbar "성실타이머"
				set {_임시명령어} to random element of all players
				make {_임시명령어} run command "z성공실패투표다음" as op 
				stop
			subtract 0.1 from {성실Timer::%uuid of loop-player%}
			set {_per} to {성실Timer::%uuid of loop-player%}/{성실MaxTimer::%uuid of loop-player%}*100
			if {_per} is between 80 and 100:
				set bossbar "성실타이머" color to blue
			else if {_per} is between 50 and 79.99:
				set bossbar "성실타이머" color to green
			else if {_per} is between 20 and 49.99:
				set bossbar "성실타이머" color to yellow
			else if {_per} is between 0 and 19.99:
				set bossbar "성실타이머" color to red
			set bossbar "성실타이머" progress to {_per}
			set bossbar "성실타이머" title to "&f[&9투표까지 남은 시간: &f[&b%{성실Timer::%uuid of loop-player%}%&9초&f]"

on rightclick:
    if name of event-item is "&f대표 선정":
        open chest with 2 rows named "&f대표 선정" to player
        set {_slot} to 0
        loop {관리자제외전체인원::*}:
            set {_head} to skull of loop-value
            set name of {_head} to "&f%loop-value%"
            set slot {_slot} of player's current inventory to {_head}
            add 1 to {_slot}
            set slot 17 of current inventory of player to paper named "&c기권"
    if name of event-item is "&f원정대 찬반투표":
        open chest with 3 rows named "&f원정대 찬반투표" to player
        set slot 11 of current inventory of player to itemsadder item "ab:chansung"
        set slot 15 of current inventory of player to itemsadder item "ab:bandae"
    if name of event-item is "&f원정대 투표":
        if {선::*} contains player:
            open chest with 3 rows named "&f원정대 투표" to player
            set slot 13 of current inventory of player to itemsadder item "ab:sunggong"
        if {악::*} contains player:
            open chest with 3 rows named "&f원정대 투표 " to player
            set slot 11 of current inventory of player to itemsadder item "ab:sunggong"
            set slot 15 of current inventory of player to itemsadder item "ab:silpae"
    if name of event-item is "&f원정대 구성":
        open chest with 3 rows named "&f원정대구성" to {대표}
        set {_slot} to 0
        loop {관리자제외전체인원::*}:
            set {_head} to skull of loop-value
            set name of {_head} to "&f%loop-value%"
            set slot {_slot} of player's current inventory to {_head}
            add 1 to {_slot}
        set slot 22 of {대표}'s current inventory to paper named "&e구성완료"
        
    if name of event-item is "&c멀린을 지목하세요.":
        open chest with 2 rows named "&c멀린을 지목하세요." to {암살자종이}
        set {_slot} to 0
        loop {관리자제외전체인원::*}:
            set {_head} to skull of loop-value
            set name of {_head} to "&f%loop-value%"
            set slot {_slot} of {암살자종이}'s current inventory to {_head}
            add 1 to {_slot}
        add 1 to {_slot}
    
    if name of event-item contain "세력 확인":
        open chest with 2 rows named "&f세력 확인" to player
        set {_slot} to 0
        loop {관리자제외전체인원::*}:
            set {_head} to skull of loop-value
            set name of {_head} to "&f%loop-value%"
            set slot {_slot} of player's current inventory to {_head}
            add 1 to {_slot}

command 승리횟수초기화:
    trigger:
        delete {게임승리횟수::*}

every 40 tick:
    loop all players:
        wipe loop-player's sidebar
        add 0 to {원정횟수}
        add 0 to {라운드1}
        add 0 to {원정성공}
        add 0 to {원정실패}
        add 0 to {원정연속반대}
        add 0 to {원정대최대인원}
        add 0 to {게임승리횟수::%loop-player%}
        set name of sidebar of loop-player to "&f진행 상황"
        set score "&e%loop-player%님의 게임&b승리&e횟수 : %{게임승리횟수::%loop-player%}%" in sidebar of loop-player to 6
        set score "&e현재 라운드 : %{원정횟수}%" in sidebar of loop-player to 5
        set score "&9원정 성공 횟수 : %{원정성공}%" in sidebar of loop-player to 2
        set score "&c원정 실패 횟수 : %{원정실패}%" in sidebar of loop-player to 1
        set score "&c원정대 출발 연속 반대 횟수 : %{원정연속반대}%" in sidebar of loop-player to 0
        set score "&e현재 원정 : %{원정횟수}%" in sidebar of loop-player to 4
        set score "&e원정대 인원 수 : %{원정대최대인원}%" in sidebar of loop-player to 3

every 1 second:
	set {접속인원수카운트} to size of all players - size of {관리자::*}

