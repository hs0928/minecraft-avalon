on inventory click:
    if inventory name is "&f대표 선정":
        cancel event
        if clicked slot is 17:
            close player's inventory
            send "{@시스템}&e투표를 완료하셨습니다. 투표가 끝날때까지 기다려주세요" to player
            play sound "minecraft:block.stone_button.click_off" with pitch 2 to player
            remove 1 paper named "&f대표 선정" from player
            add 1 to {투표수1}
            #send "%{접속인원수카운트}%, %{투표수1}%, %player%" to all players
            if {접속인원수카운트} = {투표수1}:
                make player run command "z대표투표다음" as op
                loop all players:
                    delete {대표Timer::%uuid of loop-player%}
                    delete {대표MaxTimer::%uuid of loop-player%}
                remove bossbar "대표타이머"
            else:


        else:
            if event-item is not air:
                loop all players:
                    if event-item's name is "&f%name of loop-player%":
